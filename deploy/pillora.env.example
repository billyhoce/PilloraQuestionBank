# Production environment for the PilloraQuestionBank backend.
# Copy to /opt/pillora/.env on the VM, fill in real values, then: chmod 600 /opt/pillora/.env
# This file is read by docker-compose.prod.yml (env_file) and by backup_db.sh.
# Keep these secrets OFF GitHub — CI never sees them; migrations run on the VM.

# --- Database: Supabase PRODUCTION project ---
# Settings -> Database -> Connection string -> URI. Use the Session pooler (port 5432)
# so Alembic's prepared statements work. Note the "+psycopg" driver in the scheme.
DATABASE_URL=postgresql+psycopg://postgres.<prod-project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# --- Auth ---
# Long random string, e.g. `openssl rand -hex 32`. Must NOT be left at the insecure default.
JWT_SECRET_KEY=<run: openssl rand -hex 32>

# --- Object store: AWS S3 (real, not MinIO) ---
# Do NOT set S3_ENDPOINT_URL in production — leaving it unset selects real AWS.
S3_BUCKET=pillora-question-bank-prod
AWS_ACCESS_KEY_ID=<iam-access-key>
AWS_SECRET_ACCESS_KEY=<iam-secret-key>
AWS_DEFAULT_REGION=ap-southeast-1

# --- Database backups (pg_dump -> S3) ---
# Versioned bucket for weekly + pre-migration dumps. The IAM user above must have
# s3:PutObject on this bucket.
BACKUP_S3_BUCKET=question-bank-backups

# --- AI ---
ANTHROPIC_API_KEY=<anthropic-api-key>
