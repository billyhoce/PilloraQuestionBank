# Local development template. For production values (real AWS S3, no MinIO),
# see deploy/pillora.env.example and docs/DEPLOYMENT.md.

# Supabase Postgres connection string.
# Find it in: Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Use the "Session" pooler (port 5432) for Alembic migrations
# Note that the URL format is slightly different from the standard Postgres URI; it includes the "psycopg" driver.
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Secret key for authentication
JWT_SECRET_KEY=some-secret-key

# Object store — AWS S3 (production) or MinIO (local dev)
S3_BUCKET=pillora-dev
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=ap-southeast-1
# For local MinIO (docker compose up); leave unset to use real AWS
S3_ENDPOINT_URL=http://localhost:9000

# Anthropic API key for AI features
ANTHROPIC_API_KEY=some-anthropic-api-key